# SmartHire Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://smarthire:smarthire@localhost:5432/smarthiredb001
SMARTHIRE_DB_SCHEMA=smarthire

# Used by integration tests — must differ from production schema
SMARTHIRE_TEST_SCHEMA=smarthire_test

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET=<change-me-in-production-min-32-chars>
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Keycloak
# ---------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=smarthire
KEYCLOAK_CLIENT_ID=smarthire-backend
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=<keycloak-admin-password>
# Set to false only in local dev when Keycloak runs without TLS
KEYCLOAK_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# AWS (S3 + SES)
# ---------------------------------------------------------------------------
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
S3_BUCKET_NAME=smarthire-dev
S3_FEEDBACK_BUCKET=smarthireprod
SES_FROM_ADDRESS=noreply@smarthire.internal

# ---------------------------------------------------------------------------
# Microsoft Graph API (Teams meeting links)
# ---------------------------------------------------------------------------
MS_TENANT_ID=<azure-tenant-id>
MS_CLIENT_ID=<azure-app-client-id>
MS_CLIENT_SECRET=<azure-app-client-secret>

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_PORT=8083
LOG_LEVEL=INFO
